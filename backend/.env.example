SERVER_PORT=8080

AUTH_ISSUER=http://localhost:8080
AUTH_JWT_SECRET=replace-with-at-least-32-characters-secret
AUTH_ACCESS_TOKEN_TTL_SECONDS=3600
AUTH_ALLOWED_ORIGINS=http://localhost:3000

AUTH_SERVICE_CLIENT_ID=palmery-internal-service
AUTH_SERVICE_CLIENT_SECRET=replace-with-service-client-secret

# Database (Postgres)
POSTGRES_URL=jdbc:postgresql://localhost:5432/palmery
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password

# Alternatively, Spring datasource variables (optional)
SPRING_DATASOURCE_URL=
SPRING_DATASOURCE_USERNAME=
SPRING_DATASOURCE_PASSWORD=

# Optional JPA/H2 tuning
SPRING_JPA_HIBERNATE_DDL_AUTO=update
SPRING_JPA_SHOW_SQL=false
SPRING_H2_CONSOLE_ENABLED=false
